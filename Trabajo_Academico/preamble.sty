% Numeracion de imagenes y tablas
\usepackage{chngcntr}
\counterwithin{figure}{section}
\counterwithin{table}{section}

% Numeracion de ecuaciones
\usepackage{amsmath}
\numberwithin{equation}{section}

% Formato de pagina, margenes
\pagestyle{fancy}
	\geometry{
	a4paper,
	left=30mm,
	top=30mm,
	bottom=25mm,
	right=25mm,
	headheight = 2cm
	}
\setlength{\parindent}{0.5cm}

% Configuración para evitar desbordamiento
\sloppy
\emergencystretch=1em
\tolerance=2000
\hbadness=2000

% Formato de títulos
\titleformat{\section}{\normalfont\fontsize{22pt}{24pt}\selectfont\bfseries}{\thesection.}{0.5em}{}

\titleformat{\subsection}{\normalfont\fontsize{13pt}{14pt}\selectfont\bfseries\MakeTextUppercase}{\thesubsection.}{0.5em}{}

\titleformat{\subsubsection}{\normalfont\fontsize{12pt}{12pt}\selectfont\bfseries}{\thesubsubsection.}{0.5em}{}

\titlespacing*{\section}{0pt}{0pt}{10pt}
\titlespacing*{\subsection}{0pt}{16pt}{10pt}

% Pies de imagen y tabla
\usepackage{caption}
\usepackage{subcaption}
\DeclareCaptionFont{fuenteimg}{\normalfont\fontsize{11pt}{11pt}\selectfont}
\captionsetup[figure]{font=fuenteimg,labelsep=period}
\captionsetup[table]{font=fuenteimg,labelsep=period}
\captionsetup[subfigure]{font=fuenteimg,labelsep=period,justification=centering}

% Encabezado y pie
\fancyhf{}
\lhead{\includegraphics[height=1.2cm]{Figuras/ule.jpg}}
\chead{Escuela de Ingenierías \\ Industrial, Informática y Aeroespacial}
\rhead{Página \textbf{\thepage} de \textbf{\pageref*{LastPage}}}
\lfoot{Autor: NOMBRE APELLIDOS}
\rfoot{ASIGNATURA / CURSO}
\renewcommand{\headrulewidth}{1pt}
\renewcommand{\footrulewidth}{1pt}
\setlength{\headwidth}{\textwidth}

% Modifica table of contents (TOC)
\renewcommand{\cftsubsecfont}{\scshape}
\renewcommand{\cftsecleader}{\cftdotfill{\cftdotsep}}
\renewcommand{\cfttoctitlefont}{\normalfont\fontsize{22pt}{24pt}\selectfont\bfseries}
\setlength{\cftaftertoctitleskip}{1.5cm}
\cftsetindents{section}{1em}{1em}
\cftsetindents{subsection}{1em}{2.5em}
\setlength{\cftsubsecindent}{\dimexpr\cftsecindent+\cftsecnumwidth}
\setlength{\cftsubsubsecindent}{\dimexpr\cftsubsecindent+\cftsubsecnumwidth}

% Se activan hipervinculos
\usepackage{hyperref}
\hypersetup{
    colorlinks=true,
    linktoc=all,
    linkcolor=blue,
    citecolor=blue,
    urlcolor=blue
}

% Redefinir nombres de figuras y tablas
\AtBeginDocument{%
  \renewcommand{\figureautorefname}{Figura}%
  \def\figurename{Figura}%
  \renewcommand{\tableautorefname}{Tabla}%
  \def\tablename{Tabla}%
}

% Comandos de referencia
\makeatletter
\newcommand{\figref}[1]{\hyperref[#1]{Figura~\ref*{#1}}}
\newcommand{\tabref}[1]{\hyperref[#1]{Tabla~\ref*{#1}}}
\makeatother
\newcommand{\apartadoref}[1]{\hyperref[#1]{apartado~\ref*{#1}}}
\newcommand{\Apartadoref}[1]{\hyperref[#1]{Apartado~\ref*{#1}}}
