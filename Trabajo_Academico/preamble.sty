\usepackage{geometry}
\usepackage{fontspec}
\defaultfontfeatures{Ligatures=TeX}
\usepackage{fancyhdr}
\usepackage{lastpage}
\usepackage{titlesec}
\usepackage{textcase}
\usepackage{anyfontsize}
\usepackage{newtxtext}
\usepackage{newtxmath}
\usepackage{setspace}
\onehalfspacing
\usepackage[bottom]{footmisc}
\usepackage[spanish,es-tabla]{babel}
\usepackage{graphicx}
\usepackage{tocloft}
\usepackage{float}
\usepackage{url}
\usepackage{cite}
\usepackage{etoolbox}
